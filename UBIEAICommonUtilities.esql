CREATE FUNCTION modifyField103( in_accountNo CHAR,IN env REFERENCE
					  ) RETURNS CHAR
BEGIN
		SET env.DebitAccNum.SOLEID[] = PASSTHRU('Select D.SOL_ID from ACCOUNT_VIEW D where D.FORACID =?',in_accountNo);
		DECLARE solID CHARACTER env.DebitAccNum.SOLEID[1].*;
	  	DECLARE FIELD_103_PREFIX CHAR '  026        ';--026 followed by 8 spaces
		DECLARE SoleID CHAR solID;
		DECLARE FIELD_103_BRANCHCODE_SEPARATOR CHAR '   '; -- 3 SPACES
		DECLARE FIELD_103_SUFFIX CHAR '    '; -- 4 SPACES
	
	DECLARE return_value CHARACTER FIELD_103_PREFIX||SoleID||FIELD_103_BRANCHCODE_SEPARATOR||in_accountNo||FIELD_103_SUFFIX;
  	RETURN return_value;
END;


CREATE FUNCTION RemoveSpecialCharacters( IN String CHARACTER) RETURNS CHAR
BEGIN
		SET String = REPLACE(String,'`',' ');
		SET String = REPLACE(String,'~',' ');
		SET String = REPLACE(String,'!',' ');
		SET String = REPLACE(String,'\',' ');
		SET String = REPLACE(String,'_',' ');
		SET String = REPLACE(String,'|',' ');
		SET String = REPLACE(String,'"',' ');
		SET String = REPLACE(String,';',' ');
		SET String = REPLACE(String,'$',' ');
		SET String = REPLACE(String,'@',' ');
		SET String = REPLACE(String,'#',' ');
		SET String = REPLACE(String,'%',' ');
		SET String = REPLACE(String,'^',' ');
		SET String = REPLACE(String,'&',' ');
		SET String = REPLACE(String,'[',' ');
		SET String = REPLACE(String,']',' ');
		SET String = REPLACE(String,'{',' ');
		SET String = REPLACE(String,'}',' ');
		SET String = REPLACE(String,'>',' ');
		SET String = REPLACE(String,'<',' ');
		SET String = REPLACE(String,']',' ');
		SET String = REPLACE(String,'  ',' ');
	RETURN String;
END;