	INSERT INTO Database.EAI.MESSAGE_LOG(MESSAGE_ID, INTERFACE_NAME, INTERFACE_ID, SOURCE, DESTINATION, DEPARTURE_TIME, STATUS) VALUES( inp.MsgId, env.Audit.InterfaceName, env.Audit.InterfaceID, env.Audit.Source, env.Audit.Destination, CURRENT_TIMESTAMP, 'ERROR');
	SET SQLState1 = SQLSTATE;
	SET SQLCode1 = SQLCODE;
	SET SQLErrorText1 = SQLERRORTEXT;
	SET SQLNativeError1 = SQLNATIVEERROR;
    RETURN TRUE;
 END;
CREATE FUNCTION FIN_DB(IN env REFERENCE,benfAccNum CHARACTER) RETURNS CHARACTER
BEGIN
	SET env.DATA[] = PASSTHRU('Select * from ACCOUNT_VIEW D where D.FORACID =?',benfAccNum);
	DECLARE nreFlag CHARACTER env.NRE_FLAG[1].*;
	RETURN env;
END;

CREATE FUNCTION modifyField102_InvalidAccnt( in_accountNo 	CHAR) RETURNS CHAR
BEGIN
  	DECLARE FIELD_102_PREFIX CHAR '026        ';--026 followed by 8 spaces
	DECLARE branchCode CHAR SUBSTRING(in_accountNo FROM 1 FOR 5);
	DECLARE FIELD_102_BRANCHCODE_SEPARATOR CHAR '   '; -- 3 SPACES
	DECLARE FIELD_102_SUFFIX CHAR '    '; -- 4 SPACES
	DECLARE return_value CHARACTER FIELD_102_PREFIX||branchCode||FIELD_102_BRANCHCODE_SEPARATOR||in_accountNo||FIELD_102_SUFFIX;
  	RETURN return_value;
END;

CREATE FUNCTION modifyField103_InvalidAccnt( in_accountNo 	CHAR) RETURNS CHAR
BEGIN
  	DECLARE FIELD_103_PREFIX CHAR '  026        ';--2 spaces followed by 026 followed by 8 spaces
	DECLARE branchCode CHAR SUBSTRING(in_accountNo FROM 1 FOR 5);
	DECLARE FIELD_103_BRANCHCODE_SEPARATOR CHAR '   '; -- 3 SPACES
	DECLARE FIELD_103_SUFFIX CHAR '    '; -- 4 SPACES	
	DECLARE return_value CHARACTER FIELD_103_PREFIX||branchCode||FIELD_103_BRANCHCODE_SEPARATOR||in_accountNo||FIELD_103_SUFFIX;
  	RETURN return_value;
END;

CREATE FUNCTION HEADER_DATABASE_IN( IN myInput REFERENCE  )RETURNS BOOLEAN
BEGIN
    DECLARE SQLState1 CHARACTER;   
	DECLARE SQLErrorText1 CHARACTER;   
	DECLARE SQLCode1 INTEGER;   
	DECLARE SQLNativeError1 INTEGER;
	DECLARE MessageMode CHARACTER;
	SET MessageMode = myInput.MessageMode;  
-- Make a database insert to a table that does not exist --
	IF MessageMode = 'ONL' THEN  --FOR ONLINE TRANSACTION
		INSERT INTO Database.EAI.ONL_HEADER(MESSAGEMODE,SOURCECODE,TARGETCODE,TRANSACTIONREFNO,PROCESSID,CYCLE,MSGNO,TIMESTAMP,TERMINALIP,INSTITUTIONCODE,BRANCHCODE,USERID,CURRENCY,POOLACCOUNT,DATE,TRANSFLAG1,TRANSFLAG2,CHECKER1ID,CHECKER1IDDATETIME,MESSAGETYPE,TRANSACTIONTYPE,SYSDATE) VALUES(myInput.MessageMode,myInput.SourceCode,myInput.TargetCode,myInput.TransactionRefNo,myInput.ProcessID,myInput.Cycle,myInput.MsgNo,myInput.TimeStamp,myInput.TerminalIP,myInput.InstitutionCode,myInput.BranchCode,myInput.UserID,myInput.Currency,myInput.PoolAccount,myInput.Date,myInput.TransFlag1,myInput.Transflag2,myInput.Checker1ID,myInput.Checker1IDDateTime,myInput.MessageType,myInput.TransactionType,CURRENT_DATE);
    ELSE
    --IF MessageMode = 'OFF' THEN  --FOR BATCH MODE TRANSACTION
    	INSERT INTO Database.EAI.BAT_HEADER(MESSAGEMODE,SOURCECODE,TARGETCODE,FILENAME,PROCESSID,CYCLE,MSGNO,TIMESTAMP,TERMINALIP,INSTITUTIONCODE,BRANCHCODE,USERID,CURRENCY,POOLACCOUNT,DATE,TRANSFLAG1,NOOFCREDITS,NOOFDEBITS,TOTALAMOUNTCREDITED,TOTALAMOUNTDEBITED,TRANSACTIONTYPE,SYSDATE,TOTAL_NUMBER_RECORDS,PROCESSED_COUNT) VALUES(myInput.MessageMode,myInput.SourceCode,myInput.TargetCode,myInput.FileName,myInput.ProcessID,myInput.Cycle,myInput.MsgNo,myInput.TimeStamp,myInput.TerminalIP,myInput.InstitutionCode,myInput.BranchCode,myInput.UserID,myInput.Currency,myInput.PoolAccount,myInput.Date,myInput.TransFlag1,myInput.NoOfCredits,myInput.NoOfDebits,myInput.TotalAmountCredited,myInput.TotalAmountDebited,myInput.TransactionType,CURRENT_DATE,0,0);
    END IF;
        
--Retrieve the database return codes --
	SET SQLState1 = SQLSTATE;
	SET SQLCode1 = SQLCODE;
	SET SQLErrorText1 = SQLERRORTEXT;
	SET SQLNativeError1 = SQLNATIVEERROR;
    RETURN TRUE;
END;

CREATE FUNCTION DATE_VALIDATION( IN TransactionDate REFERENCE,IN Flag REFERENCE  )RETURNS CHARACTER
BEGIN
	    		DECLARE TransDate CHARACTER ;
				DECLARE TransactionDate_Date CHARACTER;
				SET TransactionDate_Date = SUBSTRING(TransactionDate FROM 1 FOR 2);
				DECLARE TransactionDate_Month CHARACTER;
				SET TransactionDate_Month = SUBSTRING(TransactionDate FROM 3 FOR 2);
				DECLARE TransactionDate_Year CHARACTER;
				SET TransactionDate_Year = SUBSTRING(TransactionDate FROM 5 FOR 4);
				IF Flag='Y' THEN
  					SET TransDate=TransactionDate_Year||'-'||TransactionDate_Month||'-'||TransactionDate_Date;
				ELSE
					SET TransDate=TransactionDate_Year||TransactionDate_Month||TransactionDate_Date;	
				END IF;	
  			    RETURN TransDate; 
END;


