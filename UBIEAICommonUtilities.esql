--================================  FIELD 103 MODIFIED ======================
CREATE FUNCTION modifyField103_neft( in_accountNo CHAR,bankId CHAR ,soleID CHAR) RETURNS CHAR
BEGIN
	DECLARE lenin_accountNo INTEGER LENGTH(in_accountNo);
	DECLARE FIELD_103_PREFIX CHARACTER;
	DECLARE lenbankid INTEGER LENGTH(bankId);
	DECLARE lenbankexceed INTEGER (11 - lenbankid);
	IF lenbankid > 3 THEN
		SET FIELD_103_PREFIX = '  '||bankId;
		SET FIELD_103_PREFIX = FIELD_103_PREFIX||REPLICATE(' ',lenbankexceed);
	ELSE
		SET FIELD_103_PREFIX = '  '||bankId||'        ';--2 spaces followed by 026 followed by 8 spaces
	END IF;
	DECLARE lenbranchCode INTEGER LENGTH(soleID);
	DECLARE lenExceed1 INTEGER (8 - lenbranchCode);
	DECLARE FIELD_103_BRANCHCODE_SEPARATOR CHAR soleID||REPLICATE(' ',lenExceed1);
	DECLARE lenExceed2 INTEGER (19 - lenin_accountNo);
	DECLARE FIELD_103_SUFFIX CHAR in_accountNo||REPLICATE(' ',lenExceed2); 
	DECLARE return_value_length CHARACTER;
	DECLARE return_value CHARACTER;
	DECLARE return_value_temp CHARACTER;
	SET return_value_temp = FIELD_103_PREFIX||FIELD_103_BRANCHCODE_SEPARATOR||FIELD_103_SUFFIX;
	--DECLARE return_value_temp CHARACTER FIELD_103_PREFIX||FIELD_103_BRANCHCODE_SEPARATOR||FIELD_103_SUFFIX;
	SET return_value_length = LENGTH(return_value_temp);
	IF (return_value_length >40) THEN 
		SET return_value_temp=SUBSTRING(return_value_temp FROM 1 FOR 40);
	END IF;
	RETURN return_value_temp;
END;
