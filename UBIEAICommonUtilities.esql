CREATE FUNCTION buildField125_new1(remtype CHAR,transID CHAR,benAccNo CHAR,benName CHAR,benAddr1 CHAR,benAddr2 CHAR,benAddr3 CHAR,benAddr4 CHAR,benState CHAR,benZip CHAR,benIFSCCode CHAR,
                               debAccNum CHAR,BenMobNum CHAR,BenEmail CHAR,TransAmount DECIMAL,TranDate CHAR,
                               RemName CHAR,RemAddr1 CHAR,RemAddr2 CHAR,RemAddr3 CHAR,RemMob CHAR,RemEmail CHAR,CountryCode CHAR,transParticular CHAR,
                               senderReceiverInfo1 CHAR,paymentDetails1 CHAR,checkAmount DECIMAL,NeftCreditAccountNum CHARACTER,RtgsCreditAccountNum CHARACTER,IN env REFERENCE) RETURNS CHARACTER
BEGIN
	DECLARE product CHARACTER;
	DECLARE paysysID CHARACTER;
	DECLARE msgType  CHARACTER;
	DECLARE crAcctId CHARACTER;
	DECLARE chrgEventID CHARACTER;
	DECLARE msgPriority CHARACTER '99';
	--SET transParticular = 'EAI_'||product||'|'||transID;
	DECLARE toBankID CHARACTER ;
	DECLARE toBranchID CHARACTER;
	DECLARE currency CHARACTER 'INR'; 
	DECLARE senderReceiverInfo2 CHARACTER '';   ----senderCode;
	DECLARE senderReceiverInfo3 CHARACTER '';--- '//'||purpose||senderCode;
	SET senderReceiverInfo3 = '';
	DECLARE senderReceiverInfo4 CHARACTER;
	DECLARE senderReceiverInfo5 CHARACTER;
	DECLARE senderReceiverInfo6 CHARACTER '';
	DECLARE frmIFSCCode CHARACTER;
	DECLARE brcode CHARACTER; 
	DECLARE frmBankID CHARACTER '026';
	DECLARE frmbrnchID CHARACTER;
	--DECLARE checkAmount DECIMAL '200000.00';
	--DECLARE NeftCreditAccountNum CHARACTER;
	--DECLARE RtgsCreditAccountNum CHARACTER;
	DECLARE ResField125 CHARACTER '';
	DECLARE BenAddr CHARACTER '';
	DECLARE RemAddr CHARACTER '';
	DECLARE castTransAmount DECIMAL ;
	DECLARE debitAccNum CHARACTER debAccNum;
	SET castTransAmount= CAST(TransAmount AS DECIMAL);
	IF(remtype='NEFT')THEN
		SET paysysID = 'NEFT';
		SET msgType = 'N06';
		SET chrgEventID = 'NEFTO';
		SET crAcctId = NeftCreditAccountNum;
		SET senderReceiverInfo4=RemMob;
		SET senderReceiverInfo5=RemEmail;
	ELSE
		SET paysysID = 'RTGS';
		SET msgType = 'R41';
		SET chrgEventID = 'RTGSO';
		SET crAcctId = RtgsCreditAccountNum;
		SET senderReceiverInfo4='';
		SET senderReceiverInfo5='';
	END IF;
	SET env.brcode[]=(select E.br_code from Database.account_view As E where E.foracid=debitAccNum);
	Set brcode=env.brcode.*[1];
	SET env.toBankID[]=PASSTHRU('select D.bank_code from bank_view D where D.bank_identifier=? And D.paysys_id=?',benIFSCCode,paysysID);
	SET toBankID=env.toBankID.*[1];
	SET env.toBranchID[]=select D.br_code from Database.bank_view As D where D.bank_identifier=benIFSCCode And D.paysys_id=paysysID; 
	SET toBranchID= env.toBranchID.*[1];
	SET env.frmBrnchID[]=PASSTHRU('Select D.BR_CODE from account_view D where D.foracid = ?', debitAccNum);
	SET env.frmSolID[]=PASSTHRU('Select D.SOL_ID from account_view D where D.foracid = ?', debitAccNum);
	DECLARE  frmSolID CHARACTER env.frmSolID.*[1];
	SET frmbrnchID=env.frmBrnchID.*[1];
	  -- 	SET env.frmIFSCCode[]=(Select D.bank_identifier from Database.bank_view As D where D.br_code =(Select E.BR_CODE from Database.account_view As E where E.foracid=debitAccNum)) ;
	  SET env.frmIFSCCode[]=SELECT E.bank_identifier FROM Database.account_view AS D,Database.bank_view  AS E  WHERE D.foracid=debitAccNum AND E.br_code=D.br_code AND E.paysys_id=paysysID;
	SET frmIFSCCode=env.frmIFSCCode.*[1];
	--SET BenAddr=benAddr1||' '||benAddr2||' '||benAddr3;
	--SET RemAddr=RemAddr1||' '||RemAddr2||' '||RemAddr3;
	SET ResField125='20'||'|'||paysysID||'|'||msgType||'|'||'T'||'|'||frmSolID||'|'||debitAccNum||'|';
	SET ResField125=ResField125||crAcctId||'|'||CAST(CURRENT_TIMESTAMP AS CHARACTER FORMAT 'dd-MM-yyyy HH:mm:ss')||'|'||msgPriority||'|'||currency||'|'||CAST(castTransAmount AS CHARACTER)||'|'||toBankID||'|';
	SET ResField125=ResField125||toBranchID||'|'||benIFSCCode||'|'||RemName||'|'||RemAddr1||'|'||benAccNo||'|';
	SET ResField125=ResField125||benName||'|'||benAddr1||'|'||senderReceiverInfo1||'|'||chrgEventID||'|'||debitAccNum||'|';
	SET ResField125=ResField125||transParticular||'|'||frmBankID||'|'||frmbrnchID||'|'||frmIFSCCode||'||'||frmBankID||'|'||frmIFSCCode||'|||'||RemAddr2||'|'||RemAddr3||'|||||||||'||benAddr2||'|'||benAddr3||'|';
	DECLARE ResField125_1 CHARACTER  paymentDetails1||'|||||'||senderReceiverInfo2||'|'||senderReceiverInfo3||'|'||senderReceiverInfo4||'|'||senderReceiverInfo5||'|'||senderReceiverInfo6||'|||||'||benAddr4||'|';
	SET ResField125=ResField125||ResField125_1;
	SET ResField125=ResField125||benState||'|'||'INDIA'||'|'||benZip||'|';
	RETURN ResField125;
 END;
 
