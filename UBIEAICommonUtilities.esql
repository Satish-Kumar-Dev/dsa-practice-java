CREATE FUNCTION generateSTAN(STAN CHAR) RETURNS CHAR
	BEGIN
		DECLARE currDate,MonthChar CHARACTER;
		SET currDate = CAST(CURRENT_TIMESTAMP AS CHARACTER FORMAT 'yyMMddHHmmss');
		DECLARE currDate_Date CHARACTER SUBSTRING(currDate FROM 5 FOR 2);
		DECLARE currDate_Month CHARACTER SUBSTRING(currDate FROM 3 FOR 2);
		
		IF(currDate_Month = '10') THEN
			SET MonthChar = 'A';
		ELSEIF(currDate_Month = '11') THEN
			SET MonthChar = 'B';
		ELSEIF(currDate_Month = '12') THEN
			SET MonthChar = 'C';
		ELSE
			SET MonthChar = SUBSTRING(currDate_Month FROM 2 FOR 1);
		END IF;
		
		IF(stan<=999999) THEN
			SET stan=stan+1;
		ELSE
			SET stan=1;
		END IF;
		
		DECLARE serialNo CHARACTER CAST((stan) AS CHARACTER);
		SET serialNo = STAN||MonthChar||currDate_Date||REPLICATE('0', 6-LENGTH(serialNo)) || serialNo;
		RETURN serialNo;
	END;




CREATE FUNCTION TIMECHECK(IN env REFERENCE) RETURNS CHARACTER
	BEGIN
		DECLARE Time_Stamp CHARACTER;
		DECLARE Curr_Time CHARACTER ;
		SET Curr_Time = SUBSTRING(CAST(CURRENT_TIME AS CHARACTER) FROM 7 FOR 12);
		SET env.Variables.Time_Stamp[]= (SELECT  S.TIME, S.FLAG FROM Database.EAI.EAI_TIMECHECK AS S WHERE S.SOURCE='ECS'AND S.TARGET='FIN' AND S.PROCESSID='01'); 
		SET Time_Stamp=env.Variables.Time_Stamp.[1];
		--SET Curr_Time= CAST(CURRENT_TIME AS TIME);
		IF(Curr_Time >Time_Stamp AND env.Variables.Time_Stamp.[2]='Y') THEN
			RETURN 'Y';
			
				
		ELSE
			RETURN 'N';
	    END IF;	
	END;	
	
