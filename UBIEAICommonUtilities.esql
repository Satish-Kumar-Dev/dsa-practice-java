BROKER SCHEMA ubi.eai.service.provider.utilities
DECLARE I SHARED INTEGER  0;
DECLARE stan SHARED INTEGER 1;
CREATE FUNCTION splitChar( IN S CHARACTER, IN Env REFERENCE, IN Delim CHARACTER) RETURNS CHAR
BEGIN
	DECLARE P INTEGER; 
   	DECLARE I INTEGER 1;
  	REPEAT 
       SET P = POSITION(Delim IN S); 
       IF P = 0 THEN 
         SET Env.Split.Array[I] = S; 
       ELSE 
         SET Env.Split.Array[I] = LEFT(S, P - 1); 
         SET S = SUBSTRING(S FROM P + LENGTH(Delim)); 
         SET I = I + 1; 
       END IF; 
   UNTIL P = 0 
   END REPEAT;
   RETURN 'TRUE';
END; 
 
CREATE FUNCTION modifyField102_neft( in_accountNo CHAR,solID CHAR) RETURNS CHAR
BEGIN
  	DECLARE FIELD_102_PREFIX CHAR '026        ';--026 followed by 8 spaces
	DECLARE branchCode CHAR solID;
	DECLARE FIELD_102_BRANCHCODE_SEPARATOR CHAR '   '; -- 2 SPACES
	DECLARE FIELD_102_SUFFIX CHAR '    '; -- 4 SPACES
	DECLARE return_value CHARACTER FIELD_102_PREFIX||branchCode||FIELD_102_BRANCHCODE_SEPARATOR||in_accountNo||FIELD_102_SUFFIX;
  	RETURN return_value;
END;
 
