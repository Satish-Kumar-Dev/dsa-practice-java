	-----ADDED BY ROHAN FOR FILENAME TO DISPLAY IN BAM ON 24/08/2011
	SET OUTDATA.REMARKS = envPayload.remarks;
	SET OUTDATA.SOURCECODE = envPayload.srccode;
	SET OUTDATA.TARGETCODE=envPayload.trgcode;
	SET OUTDATA.PROCESSID='01';
	SET OUTDATA.TIMESTAMP = CAST(CURRENT_TIMESTAMP AS CHARACTER FORMAT 'yyyy-MM-dd');
	--SET OUTDATA.TIMESTAMP = CURRENT_TIMESTAMP;
	SET OUTDATA.POOLACCOUNT = envPayload.poolAccountNo;
	SET OUTDATA.AMOUNT = envPayload.Amount;
	SET OUTDATA.SOL_ID =  envPayload.solID;
		 --IF (LENGTH(Payload.header.Cycle)=0 and LENGTH(Payload.header.MsgNo)=0) THEN	 	   
--				IF (actionCode='000') THEN
--						 SET OUTDATA.RRN_STATUS='O';
--				ELSEIF (actionCode='907' OR actionCode='911' OR actionCode='114') THEN
--				 		
--				 		 SET OUTDATA.RRN_STATUS='P';
--				 		   
--				ELSE 
--				     	 SET OUTDATA.RRN_STATUS='B'; 
--				END IF;
--			IF LENGTH(Payload.header.Cycle)<>0 THEN
--		 			SET OUTDATA.RRN_STATUS='M';		
--		 	END IF;			 	
--		 
    SET OUTDATA.RRN_STATUS = rrn_status;
	SET OUTDATA.TX_TYPE = envPayload.TransType;
	SET OUTDATA.DATE = envPayload.date;
	SET OUTDATA.PARTICULAR1 = envPayload.PART1;
	--SET OUTDATA.RECORDNUMBER=Payload.header.RecordNumber;
    SET OUTDATA.BRANCHCODE=envPayload.solID;
    --SET OUTDATA.FILENAME = Payload.header.FileName;
    SET OUTDATA.MAKERID=''; 
    SET OUTDATA.CHECKERID=''; 
    SET OUTDATA.USERID=''; 
	RETURN OUTDATA;
END;
	
	
	
	
CREATE FUNCTION GEN_VALIDATION( srcCode CHARACTER ,trgCode CHARACTER,clrType CHARACTER,transDate CHARACTER,debitAcc CHARACTER,creditAcc CHARACTER,IN env REFERENCE) RETURNS BOOLEAN
BEGIN
	DECLARE result BOOLEAN TRUE;
	DECLARE res CHARACTER 'n';
	--SET env.variables.DEBIT_ACCT_MAST[] = select * from Database.EAI.DEBIT_ACCOUNT_MASTER AS D WHERE D.MODULE_NAME= srcCode AND D.DEBIT_ACCT_NUM=debitAcc;
    IF (clrType='C' OR clrType='c') THEN
    	SET env.variables.DEBIT_ACCT_MAST[] = select * from Database.EAI.DEBIT_ACCOUNT_MASTER AS D WHERE D.MODULE_NAME= srcCode AND D.DEBIT_ACCT_NUM=debitAcc;
    	IF (CARDINALITY(env.variables.DEBIT_ACCT_MAST.*[])=0) THEN
    		--SET env.variables.CHECK.debitAcc='F';
    		SET env.var.remarks[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='EAI' AND D.RESPONSECODE='532';
    		SET res = 'y';
    		SET env.var.errorCode = '532';
    		SET env.variables.remarks =  env.var.remarks[1].*;
    		SET result=FALSE;
    	ELSE
    		--SET result = TRUE;
    	END IF;
    ELSEIF (clrType='D' OR clrType='d') THEN
    	SET env.variables.CREDIT_ACCT_MAST[] = select * from Database.EAI.CREDIT_ACCOUNT_MASTER AS D WHERE D.SOURCEID= srcCode AND D.ACCOUNT_NUM=creditAcc;
    	IF (CARDINALITY(env.variables.CREDIT_ACCT_MAST.*[])=0) THEN
    		--SET env.variables.CHECK.creditAcc='F';
    		IF(res = 'y') THEN
	    		SET env.var.remarks1[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='EAI' AND D.RESPONSECODE='533';
	    		SET env.var.errorCode = env.var.errorCode||'|'||'533';
	    		SET env.variables.remarks =  env.variables.remarks||'|'||env.var.remarks1[1].*;
	    	ELSE
	    		SET res ='y';
	    		SET env.var.remarks1[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='EAI' AND D.RESPONSECODE='533';
	    		SET env.var.errorCode = '533';
	    		SET env.variables.remarks = env.var.remarks1[1].*;
	    	END IF;
    		SET result=FALSE;
    	ELSE
    		--SET result = TRUE;
    	END IF;
    ELSE	
    	--SET env.variables.CHECK.tranType='F';
    	 SET res ='y';
         SET env.var.remarks1[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='EAI' AND D.RESPONSECODE='531';
    	 SET env.var.errorCode = '531';
    	 SET env.variables.remarks = env.var.remarks1[1].*;
    	 SET result=FALSE;
    END IF;
    DECLARE currDate DATE CURRENT_DATE;
    DECLARE transDate_yy CHARACTER SUBSTRING(transDate FROM 1 FOR 4);
    DECLARE transDate_mm CHARACTER SUBSTRING(transDate FROM 5 FOR 2);
    DECLARE transDate_dd CHARACTER SUBSTRING(transDate FROM 7 FOR 2);
    DECLARE TRANS_DATE CHARACTER transDate_yy||'-'||transDate_mm||'-'||transDate_dd;   
    IF(CAST(TRANS_DATE AS DATE)>currDate) THEN
	    IF(res ='y') THEN 
			SET env.var.remarks2[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='EAI' AND D.RESPONSECODE='205';
			SET env.var.errorCode =  env.var.errorCode||'|'|| '205';
			SET env.variables.remarks = env.variables.remarks||'|'||env.var.remarks2[1].*;
	    ELSE
		    SET env.var.remarks2[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='EAI' AND D.RESPONSECODE='205';
		    SET env.var.errorCode = '205';
		    SET env.variables.remarks = env.var.remarks2[1].*;
	    END IF;
	    SET result=FALSE;
    ELSE
    	--SET result = TRUE;
    END IF;
    IF(trgCode <> 'FIN') THEN
	    IF(res ='y') THEN 
		    SET env.var.remarks3[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='FIN' AND D.RESPONSECODE='534';
		    SET env.var.errorCode =  env.var.errorCode||'|'|| '534';
		    SET env.variables.remarks = TRIM(env.variables.remarks)||'|'||env.var.remarks3[1].*;
	    ELSE
		    SET env.var.remarks3[] = Select D.RESPONSE_REMARK from Database.EAI.EAI_RESPONSE_MASTER AS D where D.SOURCE_TYPE='FIN' AND D.RESPONSECODE='534';
		    SET env.var.errorCode = '534';
		    SET env.variables.remarks = env.var.remarks3[1].*;
	    END IF;
	    SET result=FALSE;
    ELSE
    	--SET result = TRUE;
    END IF;
  	RETURN result;
END;

