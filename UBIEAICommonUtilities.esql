CREATE FUNCTION AccountFormat(TransactionAmount DECIMAL) RETURNS CHARACTER
BEGIN
	DECLARE amount CHARACTER '';
	DECLARE TransAmount INTEGER CAST(TransactionAmount*100 AS INTEGER);
	SET amount=CAST(TransAmount As CHARACTER);
	SET amount = REPLICATE('0', 16-LENGTH(amount))||amount;
	RETURN amount;
END;
	
	
CREATE FUNCTION modifyField102WithInUBI( in_accountNo 	CHAR) RETURNS CHAR
BEGIN
  	DECLARE FIELD_102_PREFIX CHAR '026        ';--026 followed by 8 spaces
	DECLARE branchCode CHAR SUBSTRING(in_accountNo FROM 1 FOR 5);
	DECLARE FIELD_102_BRANCHCODE_SEPARATOR CHAR '   '; -- 3 SPACES
	DECLARE FIELD_102_SUFFIX CHAR '    '; -- 4 SPACES
	DECLARE return_value CHARACTER FIELD_102_PREFIX||branchCode||FIELD_102_BRANCHCODE_SEPARATOR||in_accountNo||FIELD_102_SUFFIX;
  	RETURN return_value;
END;

CREATE FUNCTION modifyField102( in_accountNo CHAR,IN env REFERENCE) RETURNS CHAR
BEGIN
	SET env.DebitAccNum.SOLEID[] = PASSTHRU('Select D.SOL_ID from ACCOUNT_VIEW D where D.FORACID =?',in_accountNo);
	DECLARE solID CHARACTER env.DebitAccNum.SOLEID[1].*;
  	DECLARE FIELD_102_PREFIX CHAR '026        ';--026 followed by 8 spaces
	DECLARE SoleID CHAR solID;
	DECLARE FIELD_102_BRANCHCODE_SEPARATOR CHAR '   '; -- 3 SPACES
	DECLARE FIELD_102_SUFFIX CHAR '    '; -- 4 SPACES
	DECLARE return_value CHARACTER FIELD_102_PREFIX||SoleID||FIELD_102_BRANCHCODE_SEPARATOR||in_accountNo||FIELD_102_SUFFIX;
  	RETURN return_value;
END;

CREATE FUNCTION AUDIT_DATABASE_IN( IN inp REFERENCE)RETURNS BOOLEAN
BEGIN
	DECLARE SQLState1 CHARACTER;   
	DECLARE SQLErrorText1 CHARACTER;   
	DECLARE SQLCode1 INTEGER;   
	DECLARE SQLNativeError1 INTEGER;
	DECLARE Input REFERENCE TO inp.MQRFH2.usr;
	DECLARE CreationTime TIMESTAMP inp.Properties.CreationTime;
	DECLARE StatusFlag CHARACTER Input.Audit.StatusFlag;
	DECLARE inData BLOB inp.BLOB.BLOB;
	INSERT INTO Database.EAI.EAI_MESSAGE_LOG(MESSAGE_ID,INTERFACE_NAME,INTERFACE_ID,CREATION_TIME,SOURCE,DESTINATION,CURRENT_TIME,STATUS,USER,RRNUMBER,INPUTDATA,CORELID)
	VALUES(inp.MQMD.MsgId,Input.Audit.InterfaceName,Input.Audit.InterfaceID,CreationTime,Input.Audit.Source,Input.Audit.Destination,CURRENT_TIMESTAMP,Input.Audit.Status,Input.Audit.User,Input.RRN,inData,Input.CorelID);
--	ELSEIF(StatusFlag='UPDATE') THEN
--	
--						Update Database.EAI.MESSAGE_LOG As A SET STATUS=Input.Audit.Status Where 
--				                                                                 A.RRNUMBER=Input.RRN; 
--	END IF;		 
	SET SQLState1 = SQLSTATE;
	SET SQLCode1 = SQLCODE;
	SET SQLErrorText1 = SQLERRORTEXT;
	SET SQLNativeError1 = SQLNATIVEERROR;					  
    RETURN TRUE;
END;	


CREATE FUNCTION AUDIT_DATABASE_OUT(IN env REFERENCE, IN inp REFERENCE  )RETURNS BOOLEAN
BEGIN
	DECLARE SQLState1 CHARACTER;   
	DECLARE SQLErrorText1 CHARACTER;   
	DECLARE SQLCode1 INTEGER;   
	DECLARE SQLNativeError1 INTEGER;
	INSERT INTO Database.EAI.MESSAGE_LOG(MESSAGE_ID, INTERFACE_NAME, INTERFACE_ID, SOURCE, DESTINATION, DEPARTURE_TIME, STATUS) VALUES( inp.MsgId, env.Audit.InterfaceName, env.Audit.InterfaceID, env.Audit.Source, env.Audit.Destination, CURRENT_TIMESTAMP, env.Audit.Status);
	SET SQLState1 = SQLSTATE;
	SET SQLCode1 = SQLCODE;
	SET SQLErrorText1 = SQLERRORTEXT;
	SET SQLNativeError1 = SQLNATIVEERROR;
    RETURN TRUE;
END;

