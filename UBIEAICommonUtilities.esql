CREATE FUNCTION GEN_COMMON_XML( IN OutputRef REFERENCE,IN Payload REFERENCE,SolID CHARACTER ,actionCode CHARACTER,transAmount CHARACTER,RRN  CHARACTER ,IN env REFERENCE) RETURNS CHAR	
BEGIN
	SET env.ResponseRemark[]=Select D.RESPONSE_REMARK from  Database.EAI.EAI_RESPONSE_MASTER AS D WHERE D.RESPONSECODE=actionCode AND D.SOURCE_TYPE='FIN' ;
	--DECLARE TransactionAmount CHARACTER Payload.ECSMessage.Amount;
			/*Commented By Arvind Due To Wrong Entry To EAI_RESPONSE Table For Amount Value Date 11-08-2011*/
			--SET TransactionAmount = TRIM(REPLACE(TransactionAmount, '.', ''));
			--SET TransactionAmount = REPLICATE('0', 18-LENGTH(TransactionAmount))||TransactionAmount;
			
	DECLARE OUTDATA REFERENCE TO OutputRef;
	SET OUTDATA.ACCONTnO=Payload.ECSMessage.AccountNo;
	SET OUTDATA.RESPONSECODE=actionCode;
	SET OUTDATA.RESPONSECODEDESC=env.ResponseRemark.RESPONSE_REMARK;
	SET OUTDATA.STANNO=Payload.ECSMessage.SystemTraceAuditNo;
	SET OUTDATA.RETREFNO=RRN;
	-----ADDED BY ROHAN FOR FILENAME TO DISPLAY IN BAM ON 24/08/2011
	--SET OUTDATA.REMARKS=Payload.ECSMessage.particular2||'|'||Payload.header.FileName; //revert back by rohan on 25/08/2011
	 -----ADDED BY ROHAN FOR FILENAME TO DISPLAY IN BAM ON 24/08/2011
	SET OUTDATA.REMARKS=Payload.ECSMessage.particular2;
	SET OUTDATA.SOURCECODE=Payload.header.SourceCode;
	SET OUTDATA.TARGETCODE=Payload.header.TargetCode;
	SET OUTDATA.PROCESSID=Payload.header.ProcessID;
	SET OUTDATA.TIMESTAMP=CURRENT_TIMESTAMP;
	SET OUTDATA.POOLACCOUNT=Payload.header.PoolAccount;
	SET OUTDATA.AMOUNT=transAmount;
	SET OUTDATA.SOL_ID=SolID;
	--IF (LENGTH(Payload.header.Cycle)=0 and LENGTH(Payload.header.MsgNo)=0) THEN
	IF (actionCode='000') THEN
		SET OUTDATA.RRN_STATUS='O';
	ELSEIF (actionCode='917' OR actionCode='911' OR actionCode='114') THEN
		SET OUTDATA.RRN_STATUS='P';
	ELSE
		SET OUTDATA.RRN_STATUS='B'; 
	END IF;
	--			IF LENGTH(Payload.header.Cycle)<>0 THEN
	--		 			SET OUTDATA.RRN_STATUS='M';		
	--		 	END IF;			 	
	--		 
	SET OUTDATA.TX_TYPE=Payload.ECSMessage.TransactionType;
	SET OUTDATA.DATE=Payload.ECSMessage.TransactionDate;
	SET OUTDATA.PARTICULAR1=Payload.ECSMessage.particular1;
	SET OUTDATA.RECORDNUMBER=Payload.header.RecordNumber;
	SET OUTDATA.BRANCHCODE=Payload.header.BranchCode;
	SET OUTDATA.FILENAME=Payload.header.FileName;
	SET OUTDATA.MAKERID=Payload.header.Cycle; 
	SET OUTDATA.CHECKERID=Payload.header.MsgNo; 
	SET OUTDATA.USERID=Payload.header.UserID; 
	RETURN OUTDATA;
END;
	
CREATE FUNCTION GENERATE_COMMON_XML(IN OutputRef REFERENCE, actionCode CHARACTER,RRN  CHARACTER, rrn_status CHARACTER,IN env REFERENCE) RETURNS  CHAR
BEGIN
 	--SET env.ResponseRemark[]=Select D.RESPONSE_REMARK from  Database.EAI.EAI_RESPONSE_MASTER AS D WHERE D.RESPONSECODE=actionCode AND D.SOURCE_TYPE='FIN' ;
	--DECLARE TransactionAmount CHARACTER Payload.ECSMessage.Amount;
